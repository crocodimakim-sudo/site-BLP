DirectoryIndex pages_php/index.php

# 2026-04-20: HTTPS enforcement — redirect all HTTP to HTTPS (skip localhost for dev)
Options -Indexes
RewriteEngine On
# 2026-04-24: HTTPS редирект отключён до установки SSL-сертификата
# RewriteCond %{HTTPS} off
# RewriteCond %{HTTP_HOST} !^localhost$ [NC]
# RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteBase /blp/

# 2026-04-22: API endpoints
RewriteRule ^api/slider$    pages_php/api/slider.php  [L]

RewriteRule ^$              pages_php/index.php       [L]
RewriteRule ^catalog$       pages_php/catalog.php     [L]
RewriteRule ^architect$     pages_php/architect.php   [L]
RewriteRule ^devops$        pages_php/devops.php      [L]
RewriteRule ^kreplenie$     pages_php/kreplenie.php   [L]
RewriteRule ^projects$      pages_php/projects.php    [L]
RewriteRule ^sertificate$   pages_php/sertificate.php [L]
RewriteRule ^contacts$      pages_php/contacts.php    [L]
RewriteRule ^policy$        pages_php/policy.php      [L]
# 2026-04-22: Legal compliance — 3 policy pages (cookies, consent, privacy)
RewriteRule ^cookies$       pages_php/cookies.php     [L]
RewriteRule ^consent$       pages_php/consent.php     [L]
# 2026-04-20: Stage 3 — 5 new pages + diler→dealer migration (301)
RewriteRule ^dealer$        pages_php/dealer.php      [L]
RewriteRule ^diler$         /blp/dealer               [R=301,L]
RewriteRule ^faq$           pages_php/faq.php         [L]
RewriteRule ^compare$       pages_php/compare.php     [L]
RewriteRule ^install$       pages_php/install.php     [L]

# 2026-04-20: HSTS — enforce HTTPS for 1 year
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # 2026-04-20: security headers (clickjacking, MIME-sniffing, referrer, permissions)
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # 2026-04-23: CSP Report-Only — собирать нарушения 2 недели, затем перевести в enforce
    Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://api-maps.yandex.ru https://yandex.ru; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.yandex.net https://*.googleapis.com; connect-src 'self' https://www.google-analytics.com; frame-src https://yandex.ru"
</IfModule>

# 2026-04-20: block access to service files (docs, scripts, backups, git)
<FilesMatch "\.(md|py|bat|sh|log|sql|bak|env|ini|yaml|yml|json|lock)$">
    Require all denied
</FilesMatch>
RedirectMatch 404 /\.git
RedirectMatch 404 /scripts/
RedirectMatch 404 /html/
# 2026-04-23: закрыть служебные папки Claude/OMC/gstack — не попадать в деплой
RedirectMatch 404 /\.omc
RedirectMatch 404 /\.gstack
RedirectMatch 404 /\.claude_work_log
# 2026-04-23: лог-файлы заявок — только сервер
RedirectMatch 404 /blp/logs/

# 2026-04-23: правильная 404-страница (возвращает HTTP 404, не 200)
ErrorDocument 404 /blp/pages_php/404.php
ErrorDocument 500 /blp/pages_php/index.php

# 2026-04-22: Gzip compression — extended with AddEncoding + mod_filter wrapper
<IfModule mod_deflate.c>
    AddEncoding gzip .gz
    AddType application/gzip .gz
    <IfModule mod_filter.c>
        AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
    </IfModule>
    # fallback if mod_filter not available
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 2026-04-20: Browser caching — 1 year for static assets, 1 hour for HTML
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
    ExpiresByType text/html                 "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>
